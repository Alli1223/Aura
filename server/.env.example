# SQLite database file used by Prisma.
# Development default; in production (Docker) this is file:/config/aura.db
DATABASE_URL="file:./dev.db"

# API server port.
#PORT=8096

# Directory for persistent server state (DB, cache, transcodes, secrets.json).
# Defaults to ./config in development so no root permissions are needed;
# the Docker image sets CONFIG_DIR=/config (the mounted config volume).
#CONFIG_DIR=./config

#NODE_ENV=development

# Trust X-Forwarded-* headers for the client IP (used for rate limit keys and
# audit log IPs). ONLY enable this when Aura runs behind a trusted reverse
# proxy (Caddy/Traefik/nginx) that sets those headers — otherwise clients can
# spoof their IP and bypass per-IP rate limits. Default: false.
#TRUST_PROXY=false

# Comma-separated list of origins allowed to make cross-origin (CORS) requests
# with credentials, e.g. "https://app.example.com,https://other.example.com".
# Empty/unset (the default) denies all cross-origin access; the bundled web
# app is served same-origin and needs no CORS.
#CORS_ORIGINS=

# Pino log level: fatal|error|warn|info|debug|trace|silent.
# Defaults to "info" ("warn" when NODE_ENV=test). Secrets (authorization and
# cookie headers, set-cookie, password fields) are always redacted from logs.
#LOG_LEVEL=info

# Master switch for per-IP rate limiting. Defaults to enabled, except under
# NODE_ENV=test where it defaults to disabled so test suites can hammer the
# API (rate limit tests re-enable it explicitly).
#RATE_LIMIT_ENABLED=true

# Per-IP request budgets per minute. AUTH covers POST /api/auth/login and
# /register (credential guessing — strictest); REFRESH covers POST
# /api/auth/refresh; MAX is the global default for everything else.
#RATE_LIMIT_MAX=300
#RATE_LIMIT_AUTH_MAX=10
#RATE_LIMIT_REFRESH_MAX=30

# Master switch for the filesystem library watcher (chokidar). When enabled
# (the default), changes under a library's folders trigger a near-realtime
# rescan of that library. Defaults to disabled when NODE_ENV=test.
#WATCH_ENABLED=true

# Quiet period in milliseconds the watcher waits after the last filesystem
# event for a library before scanning, so a burst of changes (e.g. copying a
# whole folder) coalesces into one scan. Default: 10000 (10s).
#WATCH_DEBOUNCE_MS=10000

# Interval in milliseconds between scheduled full rescans of every library.
# Set to 0 to disable the periodic scan task (the watcher still reacts to
# changes when enabled). Default: 21600000 (6h).
#SCAN_INTERVAL_MS=21600000

# Master switch for the periodic maintenance task runner (library scans,
# transcode/artwork cleanup, DB backup). Defaults to enabled, except under
# NODE_ENV=test where it defaults to disabled so the suite never auto-schedules
# background work.
#TASKS_ENABLED=true

# Interval in milliseconds between transcode-scratch cleanups (removes HLS
# session dirs and subtitle caches orphaned by a crash). Set to 0 to disable.
# Default: 3600000 (1h).
#TRANSCODE_CLEANUP_INTERVAL_MS=3600000

# Age in milliseconds a transcode scratch dir must exceed before cleanup removes
# it. Kept above HLS_SESSION_IDLE_MS so a dir old enough to sweep cannot belong
# to a live session. Default: 3600000 (1h).
#TRANSCODE_CLEANUP_MAX_AGE_MS=3600000

# Interval in milliseconds between artwork-cache eviction runs. Set to 0 to
# disable. Default: 21600000 (6h).
#ARTWORK_EVICT_INTERVAL_MS=21600000

# Byte budget the artwork cache is trimmed to on each eviction run (least
# recently used files deleted first). Default: 1073741824 (1 GiB).
#ARTWORK_CACHE_MAX_BYTES=1073741824

# Interval in milliseconds between SQLite hot backups (VACUUM INTO) written to
# ${CONFIG_DIR}/backups. Set to 0 to disable. Default: 86400000 (24h).
#DB_BACKUP_INTERVAL_MS=86400000

# Number of most-recent database backups to keep; older ones are pruned after
# each run. Default: 7.
#BACKUP_RETENTION=7

# Master switch for trickplay (BIF-style scrub-preview sprite) generation. When
# enabled (the default), preview sprites are generated on demand on the first
# trickplay request and opportunistically pre-warmed during a manual scan.
# Defaults to disabled when NODE_ENV=test.
#TRICKPLAY_ENABLED=true

# Seconds between trickplay preview thumbnails (one frame every N seconds).
# Default: 10. Bounded 1..3600.
#TRICKPLAY_INTERVAL_SEC=10

# Width in pixels of each trickplay preview thumbnail (height follows the source
# aspect ratio). Default: 320. Bounded 64..640.
#TRICKPLAY_THUMB_WIDTH=320
