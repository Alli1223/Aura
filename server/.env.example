# SQLite database file used by Prisma.
# Development default; in production (Docker) this is file:/config/aura.db
DATABASE_URL="file:./dev.db"

# API server port.
#PORT=8096

# Directory for persistent server state (DB, cache, transcodes, secrets.json).
# Defaults to ./config in development so no root permissions are needed;
# the Docker image sets CONFIG_DIR=/config (the mounted config volume).
#CONFIG_DIR=./config

#NODE_ENV=development

# Trust X-Forwarded-* headers for the client IP (used for rate limit keys and
# audit log IPs). ONLY enable this when Aura runs behind a trusted reverse
# proxy (Caddy/Traefik/nginx) that sets those headers — otherwise clients can
# spoof their IP and bypass per-IP rate limits. Default: false.
#TRUST_PROXY=false

# Comma-separated list of origins allowed to make cross-origin (CORS) requests
# with credentials, e.g. "https://app.example.com,https://other.example.com".
# Empty/unset (the default) denies all cross-origin access; the bundled web
# app is served same-origin and needs no CORS.
#CORS_ORIGINS=

# Pino log level: fatal|error|warn|info|debug|trace|silent.
# Defaults to "info" ("warn" when NODE_ENV=test). Secrets (authorization and
# cookie headers, set-cookie, password fields) are always redacted from logs.
#LOG_LEVEL=info

# Master switch for per-IP rate limiting. Defaults to enabled, except under
# NODE_ENV=test where it defaults to disabled so test suites can hammer the
# API (rate limit tests re-enable it explicitly).
#RATE_LIMIT_ENABLED=true

# Per-IP request budgets per minute. AUTH covers POST /api/auth/login and
# /register (credential guessing — strictest); REFRESH covers POST
# /api/auth/refresh; MAX is the global default for everything else.
#RATE_LIMIT_MAX=300
#RATE_LIMIT_AUTH_MAX=10
#RATE_LIMIT_REFRESH_MAX=30
