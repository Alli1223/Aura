// Aura database schema (SQLite).
//
// SQLite has no native enum type, so enum-like columns are plain String
// fields. The allowed values are defined once in `src/db/constants.ts`
// (value unions + zod schemas) and must be validated at the application
// boundary before writing to these columns.
//
// DATABASE_URL examples:
//   development: file:./dev.db
//   production:  file:/config/aura.db

generator client {
  provider = "prisma-client-js"
  // "native" covers local development. The Docker runtime image is Debian
  // bookworm (openssl 3); pin its engine explicitly because the slim build
  // stage has no openssl and Prisma's platform detection would otherwise
  // fall back to the wrong (1.1.x) engine.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & sessions
// ---------------------------------------------------------------------------

model User {
  id                 String    @id @default(cuid())
  /// Stored lowercase; normalise before insert/lookup.
  username           String    @unique
  email              String?   @unique
  passwordHash       String
  /// One of USER_ROLES: "admin" | "user".
  role               String    @default("user")
  isEnabled          Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  /// Per-user maximum transcode quality (a quality-ladder rung name), or null
  /// for "no personal cap" (the server-wide maxQuality setting then applies).
  maxQuality         String?
  /// Per-user parental-controls cap: the highest content rating this user may
  /// see/stream (a RATING_LADDER name — "G".."NC-17"), or null for "no cap"
  /// (unrestricted). Enforced server-side alongside library grants on every
  /// media surface (see src/lib/content-rating.ts + src/auth/access.ts).
  maxContentRating   String?
  /// Preferred playback quality (a quality-ladder rung name), or null for "no
  /// preference" (the server default applies). The player starts at this rung,
  /// clamped to the user's effective max. Purely a UI default — the server-side
  /// max-quality cap is still enforced on the streaming routes.
  preferredQuality         String?
  /// Preferred subtitle language: an ISO code (e.g. "eng"), the sentinel "off"
  /// (never auto-enable subtitles), or null for "no preference". Used to
  /// pre-select a matching subtitle track in the player.
  preferredSubtitleLanguage String?
  /// Whether the player auto-advances to the next episode when one finishes.
  autoplayNextEpisode      Boolean  @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLoginAt        DateTime?

  refreshSessions RefreshSession[]
  libraryAccess   LibraryAccess[]
  grantedAccess   LibraryAccess[]  @relation("AccessGrantedBy")
  watchStates     WatchState[]
  auditLogs       AuditLog[]
  apiTokens       ApiToken[]
  playlists       Playlist[]
}

/// Personal API tokens for third-party clients/scripts. Only a sha256 hash of
/// the raw token is ever stored; the raw token (`aura_<base64url(32 bytes)>`)
/// is shown exactly once, at creation. `prefix` keeps the first characters of
/// the raw token so a user can recognise a token in listings without it ever
/// revealing enough to authenticate. `scope` gates what the token may do
/// (see API_TOKEN_SCOPES in src/db/constants.ts): "read" is GET/HEAD-only,
/// "full" acts as the user (still bounded by the user's role and grants).
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  prefix     String
  /// One of API_TOKEN_SCOPES: "read" | "full".
  scope      String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

/// Rotating refresh tokens. Only a hash of the token is stored. `replacedById`
/// links a rotated session to its successor so token reuse can be detected
/// (a presented token whose session is revoked/replaced => reuse).
model RefreshSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  replacedById String?
  userAgent    String?
  ip           String?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Libraries & access control
// ---------------------------------------------------------------------------

model Library {
  id        String   @id @default(cuid())
  name      String   @unique
  /// One of LIBRARY_TYPES: "movies" | "tv" | "anime" | "recordings" | "other".
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paths      LibraryPath[]
  access     LibraryAccess[]
  mediaItems MediaItem[]
}

model LibraryPath {
  id        String  @id @default(cuid())
  libraryId String
  library   Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  path      String

  @@unique([libraryId, path])
}

/// Per-user library access grants — THE access-control pivot. Every media
/// query for a non-admin user must join through this table.
model LibraryAccess {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  libraryId   String
  library     Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("AccessGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, libraryId])
  @@index([libraryId])
}

// ---------------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------------

/// Movies, shows, seasons and episodes in one table. Hierarchy via
/// `parentId` self-relation: episode -> season -> show. Deleting a parent
/// cascades to all descendants.
model MediaItem {
  id        String      @id @default(cuid())
  libraryId String
  library   Library     @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  /// One of MEDIA_ITEM_TYPES: "movie" | "show" | "season" | "episode".
  type      String
  parentId  String?
  parent    MediaItem?  @relation("MediaHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaItem[] @relation("MediaHierarchy")

  title                 String
  sortTitle             String
  year                  Int?
  overview              String?
  tagline               String?
  runtimeMs             Int?
  seasonNumber          Int?
  episodeNumber         Int?
  /// Absolute episode numbering used by anime.
  absoluteEpisodeNumber Int?
  contentRating         String?
  communityRating       Float?
  tmdbId                Int?
  imdbId                String?
  anilistId             Int?
  posterPath            String?
  backdropPath          String?
  addedAt               DateTime @default(now())
  updatedAt             DateTime @updatedAt

  genres          Genre[]
  files           MediaFile[]
  watchStates     WatchState[]
  collectionItems CollectionItem[]
  playlistItems   PlaylistItem[]

  @@index([libraryId, type])
  @@index([parentId])
  @@index([title])
}

model Genre {
  id   String @id @default(cuid())
  name String @unique

  mediaItems MediaItem[]
}

/// A named grouping of media items (Plex-style collections). `source` is one of
/// COLLECTION_SOURCES: "manual" (admin-curated) or "tmdb" (auto-created from a
/// movie's `belongs_to_collection` during TMDB enrichment). A tmdb collection
/// is keyed by its `tmdbCollectionId` (unique) so re-enriching a member never
/// duplicates it. `posterPath` follows the same artwork-URI convention as
/// MediaItem (e.g. `tmdb:<path>`); when null the read API falls back to the
/// first accessible member's poster. Membership + ordering live in
/// CollectionItem.
model Collection {
  id               String   @id @default(cuid())
  name             String
  /// Sort key derived from `name` (article moved to the end), like sortTitle.
  sortName         String
  overview         String?
  posterPath       String?
  /// One of COLLECTION_SOURCES: "manual" | "tmdb".
  source           String   @default("manual")
  /// TMDB collection id for auto-collections; null for manual ones. Unique when
  /// set so a re-enrich upserts the same collection.
  tmdbCollectionId Int?     @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items CollectionItem[]

  @@index([sortName])
}

/// Membership of a MediaItem in a Collection, with an explicit `order` for the
/// curated sequence. Deleting either side cascades the membership away.
model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mediaItemId  String
  mediaItem    MediaItem  @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  order        Int        @default(0)

  @@unique([collectionId, mediaItemId])
  @@index([mediaItemId])
}

/// A physical file on disk backing a media item. `size`/`mtimeMs` are BigInt
/// to survive >2GB files and millisecond mtimes.
model MediaFile {
  id          String    @id @default(cuid())
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  path        String    @unique
  size        BigInt
  mtimeMs     BigInt
  container   String?
  durationMs  Int?
  bitrate     Int?
  width       Int?
  height      Int?
  videoCodec  String?
  addedAt     DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  /// One of MEDIA_FILE_STATUSES: "available" | "missing".
  status      String    @default("available")

  streams  MediaStream[]
  chapters Chapter[]

  @@index([mediaItemId])
}

/// Chapter markers extracted from a file via ffprobe (-show_chapters). Like
/// MediaStream, the full set is replaced on every re-probe (deleteMany +
/// createMany), so `index` is always the contiguous 0-based ordinal in file
/// order and `startMs`/`endMs` are milliseconds from the start of the file.
model Chapter {
  id          String    @id @default(cuid())
  mediaFileId String
  mediaFile   MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  index       Int
  startMs     Int
  endMs       Int
  title       String?

  @@unique([mediaFileId, index])
  @@index([mediaFileId])
}

/// ffprobe stream info per file, used for playback/transcode decisions.
model MediaStream {
  id          String    @id @default(cuid())
  mediaFileId String
  mediaFile   MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  streamIndex Int
  /// One of STREAM_TYPES: "video" | "audio" | "subtitle".
  type        String
  codec       String?
  language    String?
  title       String?
  channels    Int?
  isDefault   Boolean   @default(false)
  isForced    Boolean   @default(false)

  @@unique([mediaFileId, streamIndex])
}

// ---------------------------------------------------------------------------
// Per-user state, settings & audit
// ---------------------------------------------------------------------------

model WatchState {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  positionMs  Int       @default(0)
  watched     Boolean   @default(false)
  watchedAt   DateTime?
  playCount   Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([userId, mediaItemId])
  @@index([mediaItemId])
}

/// A per-user, ordered playlist of arbitrary media items (movies/episodes).
/// Playlists are strictly private: every playlist route is scoped to the
/// caller's own rows, and another user's playlist id is cloaked as 404. Deleting
/// the owning user cascades away their playlists.
model Playlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PlaylistItem[]

  @@index([userId])
}

/// One entry in a playlist. `order` is the 0-based position within its playlist
/// (contiguous; rewritten on reorder). The @@unique guarantees an item appears
/// at most once per playlist, so a mediaItemId is a stable external handle for
/// remove/reorder. Deleting the playlist OR the media item cascades the row away
/// (a media item removed by a rescan silently drops out of every playlist).
model PlaylistItem {
  id          String    @id @default(cuid())
  playlistId  String
  playlist    Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  order       Int
  createdAt   DateTime  @default(now())

  @@unique([playlistId, mediaItemId])
  @@index([playlistId])
  @@index([mediaItemId])
}

/// Key/value server settings. `value` is JSON-encoded.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Outbound webhook: an admin-registered HTTP endpoint that receives a signed
/// POST when a subscribed event fires (see WEBHOOK_EVENT_TYPES in
/// src/lib/webhooks.ts). `events` is a JSON-encoded string array of event
/// types. `secret` is the HMAC-SHA256 key used to sign each delivery
/// (X-Aura-Signature) — SECRET: never returned in full by any route (masked in
/// listings, revealed once at creation). `lastStatus`/`lastDeliveryAt` record
/// the outcome of the most recent delivery attempt (status null = the request
/// never got an HTTP response, e.g. timeout/network error).
model Webhook {
  id             String    @id @default(cuid())
  name           String
  url            String
  /// JSON-encoded array of WEBHOOK_EVENT_TYPES this webhook subscribes to.
  events         String
  secret         String
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  lastStatus     Int?
  lastDeliveryAt DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  /// JSON-encoded details payload.
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}
